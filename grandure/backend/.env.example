# Grandure Hotel — API Keys
# Fill in only the providers you want to use

# Claude — https://console.anthropic.com
ANTHROPIC_API_KEY=your-anthropic-key

# Google Gemini — https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your-google-key

# OpenRouter (Gemma, Llama, Mistral) — https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-key

# Azure AI Foundry
AZURE_AI_ENDPOINT=https://YOUR-RESOURCE.openai.azure.com
AZURE_AI_API_KEY=your-azure-key
AZURE_MODEL_NAME=gpt-4o

# Email — Gmail with App Password (NOT your login password)
# 1. Enable 2-Step Verification on your Google account
# 2. Go to myaccount.google.com/apppasswords → generate a 16-char App Password
EMAIL_FROM=your-gmail@gmail.com
EMAIL_PASSWORD=your-16-char-app-password
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
